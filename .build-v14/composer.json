{
  "name": "fixpunkt/fp-social-bridge-cs-tools-v14",
  "description": "Isolated tooling to static-analyse fp_social_bridge against TYPO3 14 (highest supported). Mirror of .build/ but pinned to the v14 line.",
  "autoload": {
    "psr-4": {
      "Fixpunkt\\FpSocialBridge\\": "../Classes/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1.33",
    "phpstan/extension-installer": "^1.4",
    "saschaegerer/phpstan-typo3": "^3.0",
    "typo3/cms-core": "^14.0"
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true,
      "phpstan/extension-installer": true
    },
    "policy": {
      "advisories": {
        "block": false
      }
    }
  }
}
