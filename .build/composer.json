{
  "name": "fixpunkt/fp-social-bridge-cs-tools",
  "description": "Isolated dev tooling (coding standards + static analysis) for fp_social_bridge against TYPO3 14 (highest supported) — not part of the extension package.",
  "require-dev": {
    "typo3/coding-standards": "^0.8",
    "phpstan/phpstan": "^2.1.33",
    "phpstan/extension-installer": "^1.4",
    "saschaegerer/phpstan-typo3": "^3.0",
    "typo3/cms-core": "^14.0"
  },
  "autoload": {
    "psr-4": {
      "Fixpunkt\\FpSocialBridge\\": "../Classes/"
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true,
      "phpstan/extension-installer": true
    },
    "policy": {
      "advisories": {
        "block": false
      }
    }
  }
}
