{
  "name": "fixpunkt/fp-social-bridge",
  "type": "typo3-cms-extension",
  "description": "Fixpunkt Social Bridge",
  "license": "GPL-2.0-or-later",
  "authors": [
	{
	  "name": "fixpunkt für digitales GmbH",
	  "email": "office@fixpunkt.com",
	  "homepage": "https://fixpunkt.com",
	  "role": "Company"
	},
	{
	"name": "Yannik Börgener",
	"role": "Developer"
	}
  ],
  "require": {
    "php": "^8.4",
    "typo3/cms-core": "^12.4 || ^13.4 || ^14.3",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "Fixpunkt\\FpSocialBridge\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "fp_social_bridge"
    }
  },
  "require-dev": {
    "typo3/tailor": "^1.7"
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    }
  }
}
